// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum TaskStatus {
  PENDING
  DONE_TODAY
  COMPLETED
  MISSED
}
enum GoalStatus {
  ACTIVE
  COMPLETED
}

enum RepeatFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum CompletionType {
  COMPLETED
  MISSED
}

enum RewardStatus {
  SETTLED
  DEBT
}

enum TaskType {
  Habit
  OneTime
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  total_money    Decimal         @default(0)
  goals          Goal[]
  tasks          Task[]
  completionLogs CompletionLog[]
}

model Goal {
  id             String          @id @default(uuid())
  user_id        String
  title          String
  target_amount  Decimal
  current_amount Decimal         @default(0)
  status         GoalStatus      @default(ACTIVE)
  is_saving      Boolean         @default(false)
  deleted_at     DateTime?
  user           User            @relation(fields: [user_id], references: [id])
  taskGoals      TaskGoal[]
  completionLogs CompletionLog[]
}

model Task {
  id              String           @id @default(uuid())
  user_id         String
  title           String
  status          TaskStatus       @default(PENDING)
  type            TaskType         @default(OneTime)
  isRecurring     Boolean          @default(false)
  repeatFrequency RepeatFrequency? // in days, only applicable if isRecurring is true
  deadline        DateTime?
  date            DateTime         @default(now())
  user            User             @relation(fields: [user_id], references: [id])
  taskGoals       TaskGoal[]
  completionLogs  CompletionLog[]
}

model TaskGoal {
  task_id       String
  goal_id       String
  reward_amount Decimal
  task          Task    @relation(fields: [task_id], references: [id])
  goal          Goal    @relation(fields: [goal_id], references: [id])

  @@id([task_id, goal_id]) // composite primary key
}

model CompletionLog {
  id            String         @id @default(uuid())
  task_id       String
  user_id       String
  goal_id       String
  type          CompletionType
  reward_status RewardStatus   @default(SETTLED)
  money_earned  Decimal
  createdAt     DateTime       @default(now())
  task          Task           @relation(fields: [task_id], references: [id])
  user          User           @relation(fields: [user_id], references: [id])
  goal          Goal           @relation(fields: [goal_id], references: [id])
}

model SchedulerRun {
  id         String   @id @default(uuid())
  ran_at     DateTime @default(now())
  confirmed  Int
  missed     Int
}
